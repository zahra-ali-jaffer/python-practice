class Solution:
    def twoSum(self, nums: List[int], target: int) -> List[int]:
        for i in range(len(nums)): //Loop through every number using index i
            for j in range(i + 1, len(nums)): //For each i, loop through the remaining numbers using j
                if nums[i] + nums[j] == target: //if true, return their indices
                    return [i,j]
        return []



class Solution:   //Store numbers you’ve seen in a dictionary, For each number, check if its pair already exists
    def twoSum(self, nums: List[int], target: int) -> List[int]: 
        prevMap = {} #val:index
        for i, n in enumerate(nums):
            diff = target - n
            if diff in prevMap:
                return [prevMap [diff], i]
            prevMap [n] = i
        return
